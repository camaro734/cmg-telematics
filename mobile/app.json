{
  "expo": {
    "name": "CMG Telematics",
    "slug": "cmg-telematics",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "cmgtelematics",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1117"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "es.cmgnexus.telematics",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "CMG Telematics uses your location to show your position relative to fleet vehicles.",
        "NSCameraUsageDescription": "CMG Telematics uses the camera to capture geotagged photos during task execution.",
        "NSPhotoLibraryUsageDescription": "CMG Telematics saves task photos to your photo library."
      }
    },
    "android": {
      "package": "es.cmgnexus.telematics",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f1117"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#2563eb"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}

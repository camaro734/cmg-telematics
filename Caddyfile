cmgtrack.com {
    encode zstd gzip
    handle /api/* {
        reverse_proxy core-api:8010
    }
    handle /ws/* {
        reverse_proxy core-api:8010
    }
    handle /static/* {
        reverse_proxy core-api:8010
    }
    handle /uploads/* {
        reverse_proxy core-api:8010
    }
    handle /docs* {
        reverse_proxy core-api:8010
    }
    handle /redoc* {
        reverse_proxy core-api:8010
    }
    handle /openapi.json {
        reverse_proxy core-api:8010
    }
    handle /health {
        reverse_proxy core-api:8010
    }
    handle {
        reverse_proxy frontend:3000
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
        -Server
    }
}

www.cmgtrack.com {
    redir https://cmgtrack.com{uri} permanent
}

www.cmgnexus.es {
    redir https://cmgnexus.es{uri} permanent
}

cmgnexus.es {
    encode zstd gzip
    # MCP Gateway para agentes externos (OpenAI)
    @mcp_unauth {
        path /mcp*
        not header X-Agent-Key 2deCPnGIsKKuoFuhU1FgPbMqFTqkkkypKhRuJDpYG60
    }
    handle @mcp_unauth {
        respond "Unauthorized" 401
    }

    handle /mcp* {
        reverse_proxy 10.0.0.2:8083 {
            flush_interval -1
            header_up X-Real-IP {remote_host}
        }
    }

    # Content Hub — Agente Redes Sociales
    handle /hub* {
        reverse_proxy cmg-content-hub:3500 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-Proto https
        }
    }

    handle {
        reverse_proxy 10.0.0.2:8000 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-Proto https
        }
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    @workshop_sw path /static/workshop/sw.js
    header @workshop_sw Service-Worker-Allowed /taller/

    @portal_sw path /static/sw.js
    header @portal_sw Service-Worker-Allowed /
}

# Base de datos
POSTGRES_DB=cmg_telematics
POSTGRES_USER=cmg
# Generate strong passwords. Avoid URL-reserved chars (@/:?#) or URL-encode them.
POSTGRES_PASSWORD=
DB_URL=postgresql+asyncpg://cmg:POSTGRES_PASSWORD_HERE@postgres:5432/cmg_telematics
DB_URL_SYNC=postgresql://cmg:POSTGRES_PASSWORD_HERE@postgres:5432/cmg_telematics

# Redis
# Generate strong passwords. Avoid URL-reserved chars (@/:?#) or URL-encode them.
REDIS_PASSWORD=
REDIS_URL=redis://:REDIS_PASSWORD_HERE@redis:6379/0
# Max entries in telemetry.raw Redis stream (approximate trim). Default 100k ≈ 70 MB at full capacity.
STREAM_MAXLEN=100000

# API
# IMPORTANT: generate a real secret key with: openssl rand -hex 32
SECRET_KEY=

# NOTE: passwords in DB_URL and REDIS_URL must be URL-encoded.
# If your password contains @, /, :, ?, # characters, encode them first.
ENVIRONMENT=development
DOMAIN=localhost

# Notificaciones (dejar vacío en desarrollo)
SENDGRID_KEY=
TWILIO_SID=
TWILIO_TOKEN=
FCM_KEY=

# Seed inicial (solo necesario la primera vez que se ejecuta el seed)
# REQUIRED: set a strong password before running: python -m app.seeds.initial
# Not used after the admin user is created.
SEED_ADMIN_PASSWORD=

# Enrutamiento (Valhalla — servicio interno Docker, sin puerto publicado)
# Solo disponible tras ejecutar el build de teselas (ver docs/deploy.md)
VALHALLA_URL=http://valhalla:8002

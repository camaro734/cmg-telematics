ENVIRONMENT=pilot

# Base de datos TimescaleDB (PostgreSQL 16 nativo)
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@localhost:5432/cmg_telematics
POSTGRES_USER=cmg
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=cmg_telematics

# Redis (nativo, db=2 para no colisionar con otros proyectos)
REDIS_URL=redis://localhost:6379/2

# Teltonika TCP
TCP_HOST=0.0.0.0
TCP_PORT=5027

# FastAPI
SECRET_KEY=generate_with__openssl_rand_-hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=60
API_HOST=0.0.0.0
API_PORT=8010

# MQTT (Docker, opcional en piloto)
MQTT_HOST=localhost
MQTT_PORT=1883

# Frontend URL (para CORS)
FRONTEND_URL=http://your-server-ip
CORS_ORIGINS=["*"]

# Base de datos
POSTGRES_DB=cmg_telematics
POSTGRES_USER=cmg
# Generate strong passwords. Avoid URL-reserved chars (@/:?#) or URL-encode them.
POSTGRES_PASSWORD=
DB_URL=postgresql+asyncpg://cmg:POSTGRES_PASSWORD_HERE@postgres:5432/cmg_telematics
DB_URL_SYNC=postgresql://cmg:POSTGRES_PASSWORD_HERE@postgres:5432/cmg_telematics

# Redis
# Generate strong passwords. Avoid URL-reserved chars (@/:?#) or URL-encode them.
REDIS_PASSWORD=
REDIS_URL=redis://:REDIS_PASSWORD_HERE@redis:6379/0

# API
# IMPORTANT: generate a real secret key with: openssl rand -hex 32
SECRET_KEY=

# NOTE: passwords in DB_URL and REDIS_URL must be URL-encoded.
# If your password contains @, /, :, ?, # characters, encode them first.
ENVIRONMENT=development
DOMAIN=localhost

# Notificaciones (dejar vacío en desarrollo)
SENDGRID_KEY=
TWILIO_SID=
TWILIO_TOKEN=
FCM_KEY=
